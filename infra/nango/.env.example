# HomeHub local Nango stack — env template.
#
# Copy to `.env` in this directory (infra/nango/.env) and fill in real
# values. The file `.env` is already git-ignored at the repo root (`.env`
# and `.env.*` are ignored; only `.env.example` / `.env.*.example` are
# tracked). Never commit `.env`.
#
# Only NANGO_ENCRYPTION_KEY is strictly required; the rest have sensible
# defaults baked into docker-compose.yml for local dev.

# --- Encryption ---------------------------------------------------------
# REQUIRED. 32 random bytes, base64-encoded. Generate once and keep it
# forever (or plan a key-rotation migration in the admin). Losing this
# key means losing every stored provider credential.
#
#   openssl rand -base64 32
#
NANGO_ENCRYPTION_KEY=

# --- Postgres (internal to Nango) ---------------------------------------
# These back the embedded `nango-db` container. Credentials live only
# inside the compose network; they are NOT Supabase credentials and are
# never exposed to host apps.
NANGO_DB_USER=nango
NANGO_DB_PASSWORD=nango
NANGO_DB_NAME=nango

# --- Server URLs --------------------------------------------------------
# `NANGO_SERVER_URL` is the URL workers and the web app use to reach
# Nango. Locally this is always http://localhost:3003. In production
# set this to Nango's internal Railway URL.
NANGO_SERVER_URL=http://localhost:3003

# `NANGO_PUBLIC_SERVER_URL` is the URL members' browsers are redirected
# to for OAuth. In production this must be the public Nango hostname
# (e.g. https://nango.homehub.app). Locally it's the same localhost URL.
NANGO_PUBLIC_SERVER_URL=http://localhost:3003

# --- Admin dashboard ----------------------------------------------------
# Set FLAG_AUTH_ENABLED=true once a real admin account exists; until
# then the dashboard uses these basic-auth credentials.
FLAG_AUTH_ENABLED=false
NANGO_DASHBOARD_USERNAME=admin
NANGO_DASHBOARD_PASSWORD=change-me-local-only

# --- Observability ------------------------------------------------------
LOG_LEVEL=info
# Nango ships usage telemetry upstream by default. Disable locally to
# keep dev noise out of their logs.
NANGO_TELEMETRY=false

# =======================================================================
# The following variables do NOT go in this file — they are consumed by
# HomeHub workers (packages/worker-runtime) to *reach* Nango, and live
# in each worker's own env (Railway variables in prod, .env.local for
# the worker in dev):
#
#   NANGO_HOST       = http://localhost:3003     # same as NANGO_SERVER_URL
#   NANGO_SECRET_KEY = <copy from Nango admin UI once a provider is registered>
#
# See `packages/worker-runtime/src/env.ts` for the schema.
# =======================================================================
