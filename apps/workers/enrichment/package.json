{
  "name": "@homehub/worker-enrichment",
  "version": "0.0.0",
  "private": true,
  "description": "Extracts entities and facts from observed events and writes to the memory graph. Owned by @memory-background; fleshed out in M3.",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@homehub/db": "workspace:*",
    "@homehub/enrichment": "workspace:*",
    "@homehub/prompts": "workspace:*",
    "@homehub/providers-email": "workspace:*",
    "@homehub/shared": "workspace:*",
    "@homehub/worker-runtime": "workspace:*",
    "@supabase/supabase-js": "^2.104.0"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.4"
  }
}
