{
  "name": "@homehub/worker-reconciler",
  "version": "0.0.0",
  "private": true,
  "description": "Reconciles duplicate transactions (email vs budget app) and merges memory facts. Owned by @integrations + @memory-background; fleshed out in M3/M5.",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@homehub/db": "workspace:*",
    "@homehub/shared": "workspace:*",
    "@homehub/worker-runtime": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.4"
  }
}
