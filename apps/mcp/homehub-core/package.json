{
  "name": "@homehub/mcp-homehub-core",
  "version": "0.0.0",
  "private": true,
  "description": "HomeHub Core MCP server. Streamable-HTTP transport; tool catalog (nodes, entities, segments) is wired by @integrations in M3 as @frontend-chat and @memory-background provide implementations.",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@homehub/db": "workspace:*",
    "@homehub/query-memory": "workspace:*",
    "@homehub/shared": "workspace:*",
    "@homehub/worker-runtime": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.4"
  }
}
