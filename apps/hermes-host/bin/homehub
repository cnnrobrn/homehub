#!/usr/bin/env python3
"""Executable wrapper for the HomeHub Hermes CLI."""

from __future__ import annotations

import sys
from pathlib import Path

repo_server = Path(__file__).resolve().parents[1] / "server"
if repo_server.exists():
    sys.path.insert(0, str(repo_server))
else:
    sys.path.insert(0, "/opt/hermes-host/server")

from homehub_cli import main  # noqa: E402


if __name__ == "__main__":
    raise SystemExit(main())
