# Copy to `.env.local` and fill in. `.env.local` is gitignored.
# Do NOT commit real values; this file only documents the shape.

# Supabase — values from `supabase status` locally or the project dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Deployment URL (local dev default below). Used for OAuth redirects and
# the OpenRouter `HTTP-Referer` header when the app makes model calls.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — inherited from @homehub/shared base schema.
# NODE_ENV=development
# LOG_LEVEL=info
