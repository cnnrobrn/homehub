# Copy to `.env.local` and fill in. `.env.local` is gitignored.
# Do NOT commit real values; this file only documents the shape.

# ---------------------------------------------------------------------------
# Supabase (required at runtime; build-phase relaxes via `NEXT_PHASE` opt-out)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Deployment URL (local dev default below). Used for OAuth redirects and
# the OpenRouter `HTTP-Referer` header when the app makes model calls.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Invitations (HMAC key + TTL). Rotate the secret to invalidate outstanding
# invites. Minimum 32 bytes of entropy (any encoding).
# ---------------------------------------------------------------------------
INVITATION_TOKEN_SECRET=
INVITATION_TTL_DAYS=7

# ---------------------------------------------------------------------------
# Google OAuth. Required only when the "Continue with Google" path is live
# in Supabase Auth's provider config. Supabase reads the client id/secret
# from its own config — these values here are for reference / parity with
# the spec and are NOT consumed by the web app directly.
# ---------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Optional — inherited from @homehub/shared base schema.
# NODE_ENV=development
# LOG_LEVEL=info
