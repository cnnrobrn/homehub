{
  "name": "@homehub/action-executors",
  "version": "0.0.0",
  "private": true,
  "description": "Per-kind provider-call executors that plug into the action-executor worker's executor registry (M9-B). Each executor validates its action payload via Zod, resolves the target Nango connection via sync.provider_connection, and calls the appropriate provider adapter. Owned by @integrations.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@homehub/approval-flow": "workspace:*",
    "@homehub/db": "workspace:*",
    "@homehub/enrichment": "workspace:*",
    "@homehub/providers-calendar": "workspace:*",
    "@homehub/providers-email": "workspace:*",
    "@homehub/providers-financial": "workspace:*",
    "@homehub/providers-grocery": "workspace:*",
    "@homehub/worker-runtime": "workspace:*",
    "@supabase/supabase-js": "^2.104.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  }
}
