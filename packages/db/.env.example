# @homehub/db — environment placeholders.
#
# Copy to `.env` (gitignored) and fill in real values for local dev.
# The Supabase CLI reads this file when booting the stack because
# `supabase/config.toml` uses `env(VAR)` substitution for secrets.
#
# In staging/prod these values come from the hosted Supabase dashboard
# (Authentication -> Providers -> Google) — not from this file.

# Google OAuth — configure the client in Google Cloud Console, set the
# authorized redirect URI to `http://127.0.0.1:54321/auth/v1/callback`
# for local dev and the corresponding auth callback for staging/prod.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Supabase Studio's in-app AI assistant; optional for local dev.
OPENAI_API_KEY=

# SMS / Apple OAuth are disabled in M1. The keys are referenced by
# config.toml with `env(...)` so Supabase would otherwise warn about
# unresolved names; set to any placeholder to silence the warning or
# leave unset once the CLI warning is filtered.
SUPABASE_AUTH_SMS_TWILIO_AUTH_TOKEN=
SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=

# Experimental S3 config — disabled in M1. Left here so a dev who
# enables [experimental] does not silently start sending to nowhere.
S3_HOST=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
