{
  "name": "@homehub/tools",
  "version": "0.0.0",
  "private": true,
  "description": "Foreground-agent tool catalog. Each tool is a Zod schema + handler + classification (read / draft-write / direct-write). Consumed by the foreground agent loop and (eventually) the MCP server — framework-agnostic so both surfaces share one source of truth.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@homehub/db": "workspace:*",
    "@homehub/query-memory": "workspace:*",
    "@homehub/shared": "workspace:*",
    "@homehub/worker-runtime": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^4.1.4"
  }
}
