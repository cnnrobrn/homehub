{
  "name": "@homehub/auth-server",
  "version": "0.0.0",
  "private": true,
  "description": "Server-only auth + household helpers for HomeHub. Thin TypeScript wrappers over Supabase Auth (@supabase/ssr) plus the household lifecycle (create/invite/accept/list/revoke/transfer). Consumed by Next.js Server Actions in apps/web.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@homehub/db": "workspace:*",
    "@homehub/shared": "workspace:*",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^4.1.4"
  }
}
