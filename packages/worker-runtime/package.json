{
  "name": "@homehub/worker-runtime",
  "version": "0.0.0",
  "private": true,
  "description": "Shared runtime for HomeHub background workers: Supabase service client, pgmq wrapper, Nango client, OpenRouter generate() helper, structured logger, OTel tracing, graceful shutdown, per-household budget guard.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@homehub/db": "workspace:*",
    "@homehub/shared": "workspace:*",
    "@nangohq/node": "^0.70.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@supabase/supabase-js": "^2.104.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^4.1.4"
  }
}
