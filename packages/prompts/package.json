{
  "name": "@homehub/prompts",
  "version": "0.0.0",
  "private": true,
  "description": "HomeHub prompt library: markdown prompt files + a tiny runtime loader that parses the markdown sections into system/user templates and Zod schemas. Used by enrichment, consolidation, summary, suggestion, and reflection workers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "extraction",
    "rollup",
    "node-doc",
    "consolidation",
    "reflection"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@homehub/shared": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^4.1.4"
  }
}
