{
  "name": "@homehub/enrichment",
  "version": "0.0.0",
  "private": true,
  "description": "Deterministic event classifier + extraction helpers used by the enrichment worker. M2 ships a regex/keyword classifier; M3 swaps in the Kimi K2 extraction path.",
